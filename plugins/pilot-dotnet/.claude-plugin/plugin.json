{
  "$schema": "https://json.schemastore.org/claude-code-plugin-manifest.json",
  "name": "pilot-dotnet",
  "displayName": "Pilot .NET",
  "version": "0.30.0",
  "dependencies": [
    {
      "name": "pilot-core"
    }
  ],
  "description": "C# / ASP.NET Core governance: Clean Architecture, SOLID/DRY, permissions-only authorization, authentication, security headers (HSTS/CSP/anti-forgery/safe deserialization), multitenancy, EF Core patterns, API versioning/pagination/idempotency, resilience (Polly), observability, ProblemDetails error handling, caching, messaging (outbox, saga, Service Bus), background jobs, feature flags, SignalR, gRPC, BFF, testing, data protection, and NuGet governance. Ships @dotnet-reviewer, @dotnet-implementor, and @dotnet-support",
  "author": {
    "name": "AgenticPawan",
    "url": "https://github.com/AgenticPawan"
  },
  "homepage": "https://github.com/AgenticPawan/FullStack-Pilot#pilot-dotnet",
  "repository": "https://github.com/AgenticPawan/FullStack-Pilot",
  "license": "MIT",
  "lspServers": "./.lsp.json",
  "experimental": {
    "monitors": "./monitors/monitors.json"
  },
